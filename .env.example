# =============================================================================
# OpenArchiver backup configuration
# Copy this file to ".env" and fill in your values.  ".env" is gitignored.
#
# This file is used twice by docker compose:
#   - for ${VARIABLE} interpolation inside docker-compose.yml
#   - injected into the container via "env_file:" so restic sees its config
# =============================================================================

# --- Restic repository (the backup destination) -----------------------------
# S3-compatible bucket (AWS S3, Backblaze B2 S3, MinIO, Hetzner OBJECT STORAGE, ...):
RESTIC_REPOSITORY=s3:https://s3.<region>.amazonaws.com/<bucket>/openarchiver
# Alternatives (just change this one line + matching creds below):
#   local / external disk:  RESTIC_REPOSITORY=/srv/restic
#   SFTP / another server:  RESTIC_REPOSITORY=sftp:user@host:/srv/restic
#   Hetzner STORAGE BOX:    RESTIC_REPOSITORY=sftp:hetzner-sb:restic/openarchiver-prod
#     (a Storage Box speaks SFTP on port 23 — it is NOT S3. The path after the
#      host alias is where the repo lives; different paths = independent repos.
#      See the "Hetzner Storage Box" section in backup-and-restore.md.)

# Encrypts the whole repo. WITHOUT THIS PASSWORD A RESTORE IS IMPOSSIBLE.
# Generate once with:  openssl rand -base64 32
# Store it somewhere safe AND separate from the backup itself.
RESTIC_PASSWORD=change-me-to-a-long-random-string

# --- S3 credentials (only needed for s3: repositories) -----------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- SFTP backend (only for sftp: repositories, e.g. a Hetzner Storage Box) --
# Host path of your PRIVATE SSH key. It stays owned by your user and is mounted
# read-only into the container at /keys/sb_key. The connection details (hostname,
# port 23, user, this key) live in ssh/config. Leave empty for S3/local repos.
# (Requires the two extra volume mounts shown in backup-and-restore.md.)
SSH_KEY_PATH=

# --- Pointers to your running OpenArchiver install ---------------------------
# Directory of your OpenArchiver checkout (its .env + docker-compose.yml are
# backed up too — the .env holds ENCRYPTION_KEY which decrypts the stored
# mail-account credentials in the database!).
OA_PROJECT_DIR=/opt/open-archiver

# Host path of the email/attachment storage (STORAGE_LOCAL_ROOT_PATH from the
# OpenArchiver .env). This is the bulk of the data.
STORAGE_LOCAL_ROOT_PATH=/var/data/open-archiver

# Docker named volumes of the running stack. Verify with:  docker volume ls
# Default names are "<composeproject>_pgdata" / "<composeproject>_meilidata".
PG_VOLUME=openarchiver_pgdata
MEILI_VOLUME=openarchiver_meilidata
