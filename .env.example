# =============================================================================
# OpenArchiver backup configuration
# Copy this file to ".env" and fill in your values.  ".env" is gitignored.
#
# This file is used twice by docker compose:
#   - for ${VARIABLE} interpolation inside docker-compose.yml
#   - injected into the container via "env_file:" so restic sees its config
# =============================================================================
#
# How to fill this in (the file runs top-to-bottom):
#   1) RESTIC_REPOSITORY, RESTIC_PASSWORD, retention — always required (top).
#   2) ONLY your backend's block: S3 creds / SFTP / Local.
#   3) Pointers to your OpenArchiver install: paths + volume names.
# A local-disk or SFTP/Storage-Box backend also needs an extra mount (the repo
# dir resp. your SSH key), which lives in a compose overlay — copy it to
# docker-compose.override.yml (see backup-and-restore.md §8). S3 needs no overlay.
# =============================================================================

# --- Restic repository (the backup destination) -----------------------------
# S3-compatible bucket (AWS S3, Backblaze B2 S3, MinIO, Hetzner OBJECT STORAGE, ...):
RESTIC_REPOSITORY=s3:https://s3.<region>.amazonaws.com/<bucket>/openarchiver
# Alternatives (change this one line + matching creds below; local & sftp also
# need their compose overlay — see backup-and-restore.md §8):
#   local / external disk:  RESTIC_REPOSITORY=/srv/restic                       (+ docker-compose.local.yml.example)
#   SFTP / another server:  RESTIC_REPOSITORY=sftp:user@host:/srv/restic        (+ docker-compose.sftp.yml.example)
#   Hetzner STORAGE BOX:    RESTIC_REPOSITORY=sftp:hetzner-sb:restic/openarchiver-prod  (+ docker-compose.sftp.yml.example)
#     (a Storage Box speaks SFTP on port 23 — it is NOT S3. The path after the
#      host alias is where the repo lives; different paths = independent repos.
#      See the "Hetzner Storage Box" section in backup-and-restore.md.)

# Encrypts the whole repo. WITHOUT THIS PASSWORD A RESTORE IS IMPOSSIBLE.
# REQUIRED — no default: an empty value makes every command fail fast (no weak,
# publicly-known fallback). Generate once with:  openssl rand -base64 32
# Store it somewhere safe AND separate from the backup itself.
RESTIC_PASSWORD=

# --- Retention / pruning -----------------------------------------------------
# Passed to `restic forget` after each backup, then it prunes the rest. Tune
# freely. Leave EMPTY to skip forget entirely (keep everything, prune nothing).
RESTIC_FORGET_ARGS=--keep-daily 7 --keep-weekly 4 --keep-monthly 6 --prune

# --- S3 credentials (only needed for s3: repositories) -----------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- SFTP backend (only for sftp: repositories, e.g. a Hetzner Storage Box) --
# Host path of your PRIVATE SSH key. It stays owned by your user and is mounted
# read-only into the container at /keys/sb_key. The connection details (hostname,
# port 23, user, this key) live in ssh/config. Leave empty for S3/local repos.
# (Requires the SFTP overlay: cp docker-compose.sftp.yml.example docker-compose.override.yml)
SSH_KEY_PATH=

# --- Local backend (only for a path repo like /srv/restic) -------------------
# Host directory that holds the restic repo. It is mounted into the container at
# /srv/restic, so set RESTIC_REPOSITORY=/srv/restic (the in-container path) above.
# (Requires the local overlay: cp docker-compose.local.yml.example docker-compose.override.yml)
#RESTIC_LOCAL_REPO_PATH=/mnt/disk/restic

# --- Pointers to your running OpenArchiver install ---------------------------
# Directory of your OpenArchiver checkout (its .env + docker-compose.yml are
# backed up too — the .env holds ENCRYPTION_KEY which decrypts the stored
# mail-account credentials in the database!).
OA_PROJECT_DIR=/opt/open-archiver

# Host path of the email/attachment storage (STORAGE_LOCAL_ROOT_PATH from the
# OpenArchiver .env). This is the bulk of the data.
STORAGE_LOCAL_ROOT_PATH=/var/data/open-archiver

# Docker named volumes of the running stack (required). Verify with: docker volume ls
# Usual names are "<composeproject>_pgdata" / "<composeproject>_meilidata".
PG_VOLUME=openarchiver_pgdata
MEILI_VOLUME=openarchiver_meilidata
